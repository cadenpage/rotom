<?xml version="1.0"?>
<robot name="rotom" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_scale" value="0.001"/>

    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>
    <material name="yellow">
        <color rgba="1.0 1.0 0.0 1.0"/>
    </material>
    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>
    <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
    </material>





    <link name="world"/>

    <link name="ground">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/ground.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/origin2base.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <link name="link1">
    <visual>
    <!---1.570796-->
      <origin xyz="0.0166 0 -0.01285" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/link1.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.0166 0 -0.01285" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/link1.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
  </link>






  <joint name="ground" type="fixed">
    <parent link="world"/>
    <child link="ground"/>
  </joint>

  <joint name="O" type="revolute">
    <parent link="ground"/>
    <child link="link1"/>
    <origin xyz="0 -0.03 0.04025" rpy="1.570796 -1.570796 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.141593" upper="3.141593" effort="5.0" velocity="3.0"/>
  </joint>


</robot>
