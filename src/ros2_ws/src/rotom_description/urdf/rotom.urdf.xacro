<?xml version="1.0"?>
<robot name="rotom" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_scale" value="0.001"/>

    <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
    </material>
    <material name="yellow">
        <color rgba="1.0 1.0 0.0 1.0"/>
    </material>
    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>
    <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
    </material>





    <link name="world"/>

    <link name="ground">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/ground.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/ground.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0.05 0.012 -0.023" rpy="0 0 0"/>
      <material name="red"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/link1.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.05 0.012 -0.023" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/link1.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="0.0 0.02 -0.011" rpy="0 0 0"/>
      <material name="green"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/link2.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.0 0.02 -0.011" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://rotom_description/meshes/visual/link2.stl"
              scale="${mesh_scale} ${mesh_scale} ${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </collision>
  </link>







  <joint name="ground" type="fixed">
    <parent link="world"/>
    <child link="ground"/>
  </joint>

  <joint name="O" type="revolute">
    <parent link="ground"/>
    <child link="link1"/>
    <origin xyz="0 0.02 0.0292" rpy="0 0 1.570796"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.787524" upper="1.787524" effort="5.0" velocity="3.0"/>
  </joint>

  <joint name="A" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.0344 0 0.0615" rpy="0 0 1.570796"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-3.141593" upper="0.405070" effort="5.0" velocity="3.0"/>
  </joint>

  <joint name="B" type="fixed">
    <parent link="link2"/>
    <child link="tool0"/>
    <origin xyz="0 0.0996 0.029" rpy="0 0 0"/>
  </joint>



</robot>
